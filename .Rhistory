glimpse(bowl)
slice_sample(bowl, 50)
slice_sample(bowl, n = 50)
rep_slice_sample(n = 50)
rep_slice_sample(bowl, n = 50)
rep_slice_sample(bowl, n = 50) |> summarize(mean(color == "red"))
rep_slice_sample(bowl, n = 50) |> summarize(mean(color == "red"))
rep_slice_sample(bowl, n = 50, reps = 33)
rep_slice_sample(bowl, n = 50, reps = 33) |> summarize(mean(color == "red"), .by = replicate)
rep_slice_sample(bowl, n = 50, reps = 33) |> summarize(mean(color == "red"))
rep_slice_sample(bowl, n = 50, reps = 33) |> summarize(mean(color == "red")) |> view()
rep_slice_sample(bowl, n = 50, reps = 33) |> group_by(replicate) |> summarize(mean(color == "red")) |> view()
rep_slice_sample(bowl, n = 50, reps = 33) |> group_by(replicate) |> summarize(mean(color == "red")) |> ggplot(aes(mean)) + geom_histogram()
rep_slice_sample(bowl, n = 50, reps = 33) |> group_by(replicate) |> summarize(prop_red = mean(color == "red")) |> ggplot(aes(prop_red)) + geom_histogram()
rep_slice_sample(bowl, n = 50, reps = 33) |> group_by(replicate) |> summarize(prop_red = mean(color == "red")) |> ggplot(aes(prop_red)) + geom_histogram(binwidth = 0.05, boundary = 0.4, color = "white")
