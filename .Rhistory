library(tidyverse)
library(moderndive)
library(ISLR2)
# library(markdown)
UN_data_ch6 <-
un_member_states_2024 |>
select(country,
life_expectancy_2022,
fertility_rate_2022,
income_group_2024) |>
na.omit() |>
rename(life_exp = life_expectancy_2022,
fert_rate = fertility_rate_2022,
income = income_group_2024) |>
mutate(income = factor(income,
levels = c("Low income",
"Lower middle income",
"Upper middle income",
"High income")))
glimpse(UN_data_ch6)
UN_data_ch6 |> slice_sample(n = 10)
UN_data_ch6 |>
tidy_summary(columns = c(life_exp, fert_rate, income))
UN_data_ch6 |>
get_correlation(formula = fert_rate ~ life_exp)
UN_data_ch6 |>
ggplot(aes(life_exp, fert_rate, color = income)) +
geom_point() +
labs(title = "Colored scatterplot of life expectancy and fertility rate",
subtitle = "Added regression lines for income groups",
x = "Life expectancy",
y = "Fertility rate",
color = "Income group") +
geom_smooth(method = "lm",
formula = "y ~ x",
se = FALSE)
one_factor_model <-
lm(fert_rate ~ income,
data = UN_data_ch6)
coef(one_factor_model)
two_factor_model <-
UN_data_ch6 |>
lm(formula = fert_rate ~ income * life_exp)
two_factor_model |>
coef()
UN_data_ch6 |>
lm(formula = fert_rate ~ life_exp + income) |>
get_regression_points()
credit_ch6 <-
as_tibble(Credit) |>
select(debt = Balance,
credit_limit = Limit,
income = Income,
credit_rating = Rating,
age = Age)
credit_ch6 |>
glimpse()
credit_ch6 |>
slice_sample(n = 5)
credit_ch6 |>
tidy_summary()
# Scatterplot with regression line of the relationship between debt and credit_limit
credit_ch6 |>
ggplot(aes(credit_limit, debt)) +
geom_point() +
geom_smooth(method = "lm",
formula = "y ~ x",
se = FALSE) +
labs(title = "Scatterplot with regression line of Credit Limi and Debt",
x = "Credit Limit, $",
y = "Debt, $")
# Scatterplot with regression line of the relationship between debt and income
credit_ch6 |>
ggplot(aes(income, debt)) +
geom_point() +
geom_smooth(method = "lm",
formula = "y ~ x",
se = FALSE) +
labs(title = "Scatterplot with regression line of Income and Debt",
x = "Income k$",
y = "Debt $")
# debt by credit_limit
credit_ch6 |> get_correlation(debt ~ credit_limit)
# debt by income
credit_ch6 |> get_correlation(debt ~ income)
credit_ch6 |>
select(debt,
credit_limit,
income) |>
cor()
credit_ch6 |> get_correlation(debt ~ income)
credit_ch6 |> get_correlation(debt ~ income * 1e3)
# select columns of interest
credit_lc <-
credit_ch6 |>
select(debt, credit_rating, age)
# look at raw data
credit_lc |>
glimpse()
credit_lc |>
slice_sample(n = 10)
credit_lc |>
tidy_summary()
# scatterplot with regression line of credit_rating and debt
credit_lc |>
ggplot(aes(credit_rating, debt)) +
geom_point() +
geom_smooth(method = "lm",
formula = "y ~ x",
se = FALSE) +
labs(title = "Scatterplot with regression line of Credit Rating and Debt",
y = "Debt $",
x = "Credit Rating")
# scatterplot with regression line of age and debt
credit_lc |>
ggplot(aes(age, debt)) +
geom_point() +
geom_smooth(method = "lm",
formula = "y ~ x",
se = FALSE) +
labs(title = "Scatterplot with regression line of Age and Debt",
y = "Debt $",
x = "Age")
credit_lc |>
cor()
lm_debt_multi <-
credit_lc |>
lm(formula = "debt ~ credit_rating + age")
