# tidy data
un_member_states_2024
# tidy data
un_member_states_2024 |>
na.omit()
# tidy data
un_member_states_2024 |>
na.omit() |>
select(country, fertility_rate_2022, hdi_2022)
# tidy data
un_tidy <-
un_member_states_2024 |>
na.omit() |>
select(country,
fert_rate = fertility_rate_2022,
hdi = hdi_2022)
# Fit model
lm(fert_rate ~ hdi, data = un_tidy)
# Get regression points.
un_regpoints <-
lm_un |>
get_regression_points()
# tidy data
un_tidy <-
un_member_states_2024 |>
na.omit() |>
select(country,
fert_rate = fertility_rate_2022,
hdi = hdi_2022)
# Fit model
lm_un <-
lm(fert_rate ~ hdi, data = un_tidy)
# Get regression points.
un_regpoints <-
lm_un |>
get_regression_points()
un_regpoints |>
ggplot(aes(fert_rate, residual)) +
geom_point() +
geom_hline(yintercept = 0, color = "blue")
un_regpoints |>
ggplot(aes(fert_rate_hat, residual)) +
geom_point() +
geom_hline(yintercept = 0, color = "blue")
# Check linearity by plotting residuals over estimates
un_regpoints |>
ggplot(aes(fert_rate_hat, residual)) +
geom_point() +
geom_hline(yintercept = 0, color = "blue")
# Plot histogram of residuals
un_regpoints |>
ggplot(aes(residual, after_stat(density))) +
geom_histogram() +
geom_density(color = "blue")
# Plot histogram of residuals
un_regpoints |>
ggplot(aes(residual, after_stat(density))) +
geom_histogram() +
geom_density(color = "blue")
# Plot qq-plot
un_regpoints |>
ggplot(aes(sample = residual)) +
geom_qq() +
geom_qq_line(color = "blue")
# Plot residuals against regressor variable
un_regpoints |>
ggplot(aes(hdi, residual)) +
geom_point(alpha = 0.6) +
geom_hline(yintercept = 0)
